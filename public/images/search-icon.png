<script>
    const loadmore = document.querySelector('#loadmore');
    let currentItems = 0;
    const itemsPerLoad = window.innerWidth <= 768 ? 10 : 10;

    loadmore.addEventListener('click', () => {
        const elementList = [...document.querySelectorAll('.list1 .list-element1')];
        const totalItems = elementList.length;

        // Ensure the items load in sequence
        for (let i = currentItems; i < Math.min(currentItems + itemsPerLoad, totalItems); i++) {
            elementList[i].style.display = 'block';
        }

        currentItems += itemsPerLoad;

        if (currentItems >= totalItems) {
            loadmore.style.display = 'none';
        }
    });


</script>
<script>
    function openCity(evt, cityName) {
        var i, tabcontent, tablinks;
        tabcontent = document.getElementsByClassName("tabcontent");
        for (i = 0; i < tabcontent.length; i++) {
            tabcontent[i].style.display = "none";
        }
        tablinks = document.getElementsByClassName("tablinks");
        for (i = 0; i < tablinks.length; i++) {
            tablinks[i].className = tablinks[i].className.replace(" active", "");
        }
        document.getElementById(cityName).style.display = "block";
        evt.currentTarget.className += " active";
    }
</script>





