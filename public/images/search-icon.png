    .main-menu .navigation>li li>a:hover {
        color: #fff;
        background-color: #1f5c9e;

    }

    #col {
        margin-top: -1%;
    }

    #about1 {
        width: 454px;
        height: 178%;
        font-size: 14px;
    }

    #colmd {
        margin-top: -2%;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        line-height: 25px;
        top: 0px !important;
    }

    .goog-te-banner-frame.skiptranslate,
    .goog-te-gadget img {
        display: none;
    }

    .skiptranslate {
        display: none !important;
    }

    @media only screen and (max-width: 486px) {
        .mb-4 {
            margin-top: 174px;
        }

        .search-btn {
            display: none;
        }
    }

    .mySlides {
        display: none;
    }

    .w3-section,
    .w3-code {
        margin-top: 0px !important;
        margin-bottom: 0px !important;
    }

    .w3-animate-right {
        position: relative;
        animation: animateright 0.4s
    }

    @keyframes animateright {
        from {
            right: -300px;
            opacity: 0
        }

        to {
            right: 0;
            opacity: 1
        }
    }

    body {
        line-height: 25px;
    }

    ul,
    li {
        list-style: disc;
        margin-left: 9px;
    }

    hr {

        margin: 8px auto;

    }

    .spname {
        font-size: 18px;
        color: #1f5c9e;
        font-weight: 300;
        padding: 0px 24px;

    }

    .mb18 {
        margin-bottom: 18px;
    }

    .spname:hover {

        color: #fff;

    }

    .eventimg {
        height: 73px;
    }

    .mt10 {
        padding: 6px;
        margin-top: 10px;
    }

    .ipccss {
        height: 85px !important;
        s border-radius: 9px;
        padding: 10px 5px 10px 5px;
    }

    .ipccs {
        height: 111px !important;
        s border-radius: 9px;
        padding: 20px 14px 10px 14px;
    }

    .ftn {
        font-size: 15px;
        /* line-height: 18px; */
        font-weight: 300;
        line-height: 20px;
    }

    .ml20 {
        margin-left: 20px;
    }

    li.listshow.llpdm {
        text-align: center;
    }

    .row.ahk1.active {
        padding-left: 21px;
    }

    .row.ahk1.active:hover {
        background: #1f5c9e;
        color: #fff;
    }

    .mrtag-bot-tooltip1.mrtag-bot-span {
        display: none;
    }

    .mrtag-bot-tooltip.mrtag-bot-span {
        display: none;
    }

    /* width */
    ::-webkit-scrollbar {
        width: 10px;
    }

    /* Track */
    ::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    /* Handle */
    ::-webkit-scrollbar-thumb {
        background: #1f5c9e;
    }

    /* Handle on hover */
    ::-webkit-scrollbar-thumb:hover {
        background: #555;
    }

    /*.social-icon-one li a {*/
    /*    color: #fff;*/
    /*}*/

.helpline-container {
    display: flex;
    justify-content: space-between;
    gap: 5px;
    list-style: none;
    padding: 0;
    margin: 0;
}

.helpline-item {
    display: flex;
    align-items: center;
    padding: 0px 5px;
    margin: 2   px 0;
    border-radius: 5px;
    font-family: Arial, sans-serif;
}

.helpline-item img {
    width: 25px;
    height: 25px;
    margin-right: 0px;
    object-fit: contain;
    margin-bottom: -7px;
}

.ambulance {
    background-color: #e53935;
    color: white;
}

.appointments {
    background-color: #bdbdbd;
    color: #09151a;
}

.helpline-text {
    margin-right: 0px;
    font-size: 9px;
    color: white;
    font-weight: bold;
}

.helpline-number {
    font-size: 9px;
    font-weight: bold;
}

