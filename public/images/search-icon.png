    <!-- Google tag (gtag.js) -->
    <script async="" src="./search-icon_files/js(1)"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());

        gtag('config', 'UA-169306414-1');
          document.addEventListener("DOMContentLoaded", function () {
        function gtag() { dataLayer.push(arguments); }
    const modal = document.getElementById("myCustomModal");
        gtag('js', new Date());
    const closeBtn = document.querySelector(".custom-close");
        gtag('config', 'UA-169306414-1');
    // Close modal
    closeBtn.onclick = () => {
        modal.style.display = "none"
        sessionStorage.setItem("location", "banjarahills");
    };
    // Close on outside click
    window.onclick = (e) => {
      if (e.target === modal) modal.style.display = "none";
    }
    // Check for location in URL or sessionStorage
    const urlParams = new URLSearchParams(window.location.search);
    const hasLocationParam = urlParams.has("location");
    const hasSessionLocation = sessionStorage.getItem("location");
    // Show modal only if location is not in URL AND not in session
    if (!hasLocationParam && !hasSessionLocation) {
      modal.style.display = "";
    }
    // Make selectBranch globally accessible
    window.selectBranch = function(branch) {
    //   modal.style.display = "";
      sessionStorage.setItem("location", branch);
      // Normalize and redirect based on branch
      const normalizedBranch = branch.trim().toLowerCase();
      let baseUrl;
      if (normalizedBranch === "zapx") {
        baseUrl = "https://aighospitals.com/zapx";
      } else if (normalizedBranch === "gachibowli") {
        baseUrl = "https://aighospitals.com";
      } else if (normalizedBranch === "banjarahills") {
        baseUrl = "https://aighospitals.com/banjara-hills";
      } else {
        baseUrl = "https://aighospitals.com/";
      }
      window.location.href = baseUrl;
    };
  });
    </script>
<style type="text/css">
    .evawhel{
